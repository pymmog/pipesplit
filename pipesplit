#!/usr/bin/env bash
set -euo pipefail

# pipesplit — manage audio routing for streaming
#
# Usage:
#   pipesplit                   # connect to last-used output device
#   pipesplit toggle            # cycle to next output device
#   pipesplit <key>             # force a specific device (key from outputs.conf)
#   pipesplit status            # show current state
#   pipesplit stop              # stop auto-router
#
# Keybind for Hyprland:
#   bind = SUPER, F8, exec, ~/.local/bin/pipesplit toggle

CONF="${XDG_CONFIG_HOME:-$HOME/.config}/pipesplit/outputs.conf"
STATE_FILE="${XDG_STATE_HOME:-$HOME/.local/state}/pipesplit-output"

declare -A DEVICES=()
declare -A LABELS=()
declare -a DEVICE_KEYS=()
declare -a HP_SINKS=()
declare -a VIRTUAL_SINKS=()

# ── config ────────────────────────────────────────────────────────────

load_config() {
    if [[ ! -f "$CONF" ]]; then
        err "Config not found: $CONF"
        err "Expected: $CONF"
        exit 1
    fi

    while IFS= read -r line; do
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        [[ "$line" =~ ^[[:space:]]*$ ]] && continue

        if [[ "$line" =~ ^[[:space:]]*hp_sinks[[:space:]]*=[[:space:]]*(.+)$ ]]; then
            read -ra HP_SINKS <<< "${BASH_REMATCH[1]}"
        elif [[ "$line" =~ ^[[:space:]]*virtual_sinks[[:space:]]*=[[:space:]]*(.+)$ ]]; then
            read -ra VIRTUAL_SINKS <<< "${BASH_REMATCH[1]}"
        elif [[ "$line" =~ ^[[:space:]]*([^=[:space:]]+)[[:space:]]*=[[:space:]]*([^,]+)[[:space:]]*,[[:space:]]*(.+)$ ]]; then
            local key="${BASH_REMATCH[1]}"
            local pattern="${BASH_REMATCH[2]}"
            local label="${BASH_REMATCH[3]}"
            pattern="${pattern%"${pattern##*[![:space:]]}"}"
            label="${label%"${label##*[![:space:]]}"}"
            DEVICES[$key]="$pattern"
            LABELS[$key]="$label"
            DEVICE_KEYS+=("$key")
        fi
    done < "$CONF"

    if [[ ${#DEVICE_KEYS[@]} -eq 0 ]]; then
        err "No output devices defined in $CONF"
        exit 1
    fi
    if [[ ${#HP_SINKS[@]} -eq 0 ]]; then
        err "No hp_sinks defined in $CONF"
        exit 1
    fi
}

# ── helpers ──────────────────────────────────────────────────────────

log()    { printf '\033[1;34m→\033[0m %s\n' "$*"; }
ok()     { printf '\033[1;32m✓\033[0m %s\n' "$*"; }
warn()   { printf '\033[1;33m!\033[0m %s\n' "$*"; }
err()    { printf '\033[1;31m✗\033[0m %s\n' "$*" >&2; }

notify() {
    notify-send -t 3000 -i audio-card "pipesplit" "$1" 2>/dev/null || true
}

resolve_output_node() {
    pw-cli ls Node 2>/dev/null \
        | grep -oP 'node\.name = "\K[^"]+' \
        | grep "^alsa_output" \
        | grep -m1 "$1" || true
}

get_current() {
    local saved
    saved=$(cat "$STATE_FILE" 2>/dev/null || true)
    if [[ -n "$saved" && -v DEVICES[$saved] ]]; then
        echo "$saved"
    else
        echo "${DEVICE_KEYS[0]}"
    fi
}

get_next() {
    local current
    current=$(get_current)
    local i
    for i in "${!DEVICE_KEYS[@]}"; do
        if [[ "${DEVICE_KEYS[$i]}" == "$current" ]]; then
            local next=$(( (i + 1) % ${#DEVICE_KEYS[@]} ))
            echo "${DEVICE_KEYS[$next]}"
            return
        fi
    done
    echo "${DEVICE_KEYS[0]}"
}

disconnect_device() {
    local node="$1"
    for sink in "${HP_SINKS[@]}"; do
        pw-link -d "${sink}:monitor_FL" "${node}:playback_FL" 2>/dev/null || true
        pw-link -d "${sink}:monitor_FR" "${node}:playback_FR" 2>/dev/null || true
    done
}

connect_device() {
    local node="$1"
    for sink in "${HP_SINKS[@]}"; do
        pw-link "${sink}:monitor_FL" "${node}:playback_FL" 2>/dev/null || true
        pw-link "${sink}:monitor_FR" "${node}:playback_FR" 2>/dev/null || true
    done
}

# ── switch logic ─────────────────────────────────────────────────────

switch_to() {
    local target="$1"
    local pattern="${DEVICES[$target]}"
    local label="${LABELS[$target]}"

    local node
    node=$(resolve_output_node "$pattern")
    if [[ -z "$node" ]]; then
        err "$label not found. Is it plugged in?"
        notify "$label not found"
        return 1
    fi
    ok "Found output: $node"

    # Disconnect hp sinks from ALL output devices (clean slate)
    log "Disconnecting from all output devices..."
    for key in "${!DEVICES[@]}"; do
        local dev_node
        dev_node=$(resolve_output_node "${DEVICES[$key]}")
        if [[ -n "$dev_node" ]]; then
            disconnect_device "$dev_node"
        fi
    done

    # Connect hp sinks → target device only
    log "Connecting headphone sinks → $label..."
    connect_device "$node"
    ok "Headphones → $label"

    # Set as system default so new apps use this device
    local node_id
    node_id=$(pw-cli ls Node 2>/dev/null \
        | grep -B1 "node.name = \"$node\"" \
        | grep -oP 'id \K\d+' | head -1 || true)
    if [[ -n "$node_id" ]]; then
        wpctl set-default "$node_id"
        ok "Default output → $label"
    fi

    # Move all existing streams on hardware outputs to the new device.
    # Streams managed by pipesplit (on virtual sinks) are left alone.
    log "Moving existing streams → $label..."
    local sink_id
    sink_id=$(pactl list sinks short 2>/dev/null \
        | grep "$node" | awk '{print $1}' || true)
    if [[ -n "$sink_id" ]]; then
        pactl list sink-inputs short 2>/dev/null | while IFS=$'\t' read -r input_idx sink_idx _ _ _; do
            local current_sink
            current_sink=$(pactl list sinks short 2>/dev/null \
                | awk -v id="$sink_idx" '$1 == id {print $2}' || true)
            if [[ "$current_sink" == alsa_output* && "$sink_idx" != "$sink_id" ]]; then
                pactl move-sink-input "$input_idx" "$sink_id" 2>/dev/null && \
                    log "  Moved stream $input_idx → $label" || true
            fi
        done
    fi

    # Save state
    mkdir -p "$(dirname "$STATE_FILE")"
    echo "$target" > "$STATE_FILE"
    notify "Switched to $label"

    # Start/restart the auto-router
    if [[ -n "${PIPESPLIT_NO_RESTART:-}" ]]; then
        : # skip restart when called from service ExecStartPre
    elif systemctl --user is-enabled pipesplit.service &>/dev/null; then
        log "Restarting auto-router..."
        systemctl --user restart pipesplit.service
    else
        log "Running one-time app routing..."
        ~/.local/bin/pipesplit-router --once 2>/dev/null || true
    fi

    echo ""
    ok "All done!"
}

# ── commands ─────────────────────────────────────────────────────────

load_config

cmd="${1:-connect}"
case "$cmd" in
    toggle)
        switch_to "$(get_next)"
        ;;
    stop)
        systemctl --user stop pipesplit.service 2>/dev/null && ok "Auto-router stopped" || warn "Auto-router was not running"
        ;;
    status)
        current=$(get_current)
        echo "Output device: ${LABELS[$current]}"
        echo ""
        echo "=== Virtual sinks ==="
        for sink in "${VIRTUAL_SINKS[@]}"; do
            if pw-cli ls Node 2>/dev/null | grep -q "node.name = \"$sink\""; then
                ok "$sink"
            else
                err "$sink (not found)"
            fi
        done
        echo ""
        echo "=== Auto-router ==="
        if systemctl --user is-active pipesplit.service &>/dev/null; then
            ok "Running"
        else
            warn "Not running (start with: pipesplit)"
        fi
        echo ""
        echo "=== App → sink links ==="
        vsinks_pat=$(IFS='|'; echo "${VIRTUAL_SINKS[*]}")
        pw-link -l 2>/dev/null | grep -E "(${vsinks_pat}):playback" || echo "  (none)"
        echo ""
        echo "=== Headphone → output links ==="
        hpsinks_pat=$(IFS='|'; echo "${HP_SINKS[*]}")
        pw-link -l 2>/dev/null | grep -E "(${hpsinks_pat}):monitor" || echo "  (none)"
        ;;
    connect)
        switch_to "$(get_current)"
        ;;
    *)
        if [[ -v DEVICES[$cmd] ]]; then
            switch_to "$cmd"
        else
            keys=$(IFS='|'; echo "${DEVICE_KEYS[*]}")
            echo "Usage: pipesplit [toggle|${keys}|status|stop|connect]"
            exit 1
        fi
        ;;
esac
